{
  "name": "@zeeshan8281/meshkit",
  "version": "0.2.0",
  "description": "Multi-agent mesh SDK - define agents, wire topologies, trace everything",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./node_modules/@zeeshan8281/registry/dist/index.d.ts",
      "import": "@zeeshan8281/registry"
    },
    "./transport": {
      "types": "./node_modules/@zeeshan8281/transport/dist/index.d.ts",
      "import": "@zeeshan8281/transport"
    },
    "./mcp": {
      "types": "./node_modules/@zeeshan8281/mcp/dist/index.d.ts",
      "import": "@zeeshan8281/mcp"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agents",
    "multi-agent",
    "mcp",
    "mesh",
    "orchestration"
  ],
  "author": "Zeeshan",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@zeeshan8281/registry": "^0.1.0",
    "@zeeshan8281/transport": "^0.1.0",
    "@zeeshan8281/mcp": "^0.1.0",
    "openai": "^4.77.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
    "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zeeshan8281/meshkit.git"
  },
  "publishConfig": {
    "access": "public"
  }
}